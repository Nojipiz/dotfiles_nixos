{
  "base_keymap": "JetBrains",
  "theme": "One Dark Pro",
  "icon_theme": "Material Icon Theme",
  "telemetry": {
    "metrics": true,
  },
  "tab_size": 2,
  "relative_line_numbers": "enabled",
  "vim_mode": true,
  "ui_font_size": 14,
  "ui_font_family": "JetBrains Mono",
  "buffer_font_size": 12,
  "buffer_font_family": "JetBrains Mono",

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 1600,
    "scroll_debounce_ms": 50,
  },
  "project_panel": {
    "dock": "left"
  },

  "format_on_save": "off",
  "terminal": {
    "shell":  {
      // Make sure to change this code if pkgs.fish is removed.
      "program": "/run/current-system/sw/bin/fish"
    }
  },
  "lsp": {
    "metals": {
      "binary": {
        "path": "/run/current-system/sw/bin/metals",
      },

      "initialization_options": { "isHttpEnabled": true },
      "settings": {
        // Best effort for Scala 3 projects
        "enableBestEffort": true,
        // Using SBT/Mill bsp servers instead of bloop
        "defaultBspToBuildTool": true,

        "inlayHints": {
          "inferredTypes": {
            "enable": false,
          },
          "typeParameters": {
            "enable": true,
          },
          "implicitArguments": {
            "enable": false,
          },
          "hintsInPatternMatch": {
            "enable": true,
          },
        },
      },
    },
  },
}
